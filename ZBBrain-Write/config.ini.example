# ============================================================
# ZBBrain-Write 配置文件模板
# EPC总承包微信公众号自动化文章生成工具
# ============================================================
# 使用说明：复制此文件为 config.ini 并填入您的实际配置

[搜狗微信搜索]
# 搜狗微信搜索URL（需要替换为您自己的搜索链接）
搜狗微信搜索网址 = https://www.sogou.com/sogou?query=YOUR_KEYWORD
# 搜索关键词（从keywords.txt文件依次读取）
默认搜索关键词 = EPC总承包
# 关键词轮换状态文件
关键词轮换状态文件 = ./keyword_rotation.json
# 每次搜索爬取的页数
默认翻页页数 = 5
最大翻页页数 = 10

[总包大脑]
# 秘塔AI搜索地址（需要替换为您自己的秘塔AI链接）
总包大脑网址 = https://metaso.cn/s/YOUR_LINK
# 浏览器用户数据目录
用户数据目录 = ./browser_data
# 等待回复的最长时间（秒）
# 【v3.6.2更新】长思考模式下会自动延长到至少900秒(15分钟)
最大等待回复时间 = 900
# 检查回复的间隔时间（秒）
回复检查间隔 = 5
# 回复人设提示词轮换配置（在 Prompt 文件夹中放置不同版本的提示词）
提示词轮换配置文件 = ./prompt_rotation.json
提示词文件夹 = ./Prompt
# 【v3.6.2新增】长思考模式配置
# 是否在发送问题前切换到长思考模式（true/false）
# 长思考模式可获得更详细、更深度的回复，但响应时间更长
启用长思考模式 = true

[智谱AI]
# 智谱AI API配置（需要替换为您的API Key）
api key = YOUR_ZHIPU_API_KEY
api 地址 = https://open.bigmodel.cn/api/paas/v4/chat/completions
# 模型配置【0成本优化 V2.0】
# 推荐使用 GLM-4.7-Flash: 200K上下文，同级别最强能力，完全免费！
# 可选模型:
#   - glm-4.7-flash (推荐): 完全免费，200K上下文，最强通用能力
#   - glm-4-flash: 完全免费，128K上下文
#   - glm-4-plus: 付费模型，如需极致质量可选用
低成本模型名称 = glm-4.7-flash
高质量模型名称 = glm-4.7-flash
# 图片生成模型 (cogview-3-flash 免费)
图片生成模型 = cogview-3-flash
# 生成问题的最小字符数
问题最小字符数 = 50
# 回复的最小字符数
回复最小字符数 = 500

[微信公众号]
# 公众号配置（需要替换为您的公众号配置）
# 注意：多公众号轮换功能已启用，请在 wechat_accounts.json 中配置所有公众号
# 配置文件路径（默认为 ./wechat_accounts.json）
公众号配置文件 = ./wechat_accounts.json
# 以下为默认公众号配置（当 wechat_accounts.json 不存在时使用）
appid = YOUR_WECHAT_APPID
appsecret = YOUR_WECHAT_APPSECRET
# 封面图片路径
封面图片路径 = ./cover.jpg
# 封面轮换状态文件
封面轮换状态文件 = ./cover_rotation.json
# 默认作者名称
默认作者 = 总包大脑
# 是否标记为原创（1=原创，0=非原创）
声明原创 = 1
# 是否开启评论（1=开启，0=关闭）
开启评论 = 1
# 定时发布设置
# 注意：微信API不支持通过API设置定时发布，需手动在公众号后台设置
# 此选项暂不可用
启用定时发布 = false
# 定时发布延迟分钟数（草稿创建后多少分钟发布）
定时发布延迟分钟 = 15

[文章主题]
# 可用主题：
# - 秋日暖光 (autumn-warm) - 温暖治愈，橙色调，文艺美学
# - 春日清新 (spring-fresh) - 清新自然，绿色调，生机盎然
# - 深海静谧 (ocean-calm) - 深沉冷静，蓝色调，专业稳重
# - 优雅金 (elegant-gold) - 高端大气，金色调，商务专业
# - 活力红 (bold-red) - 活力热情，红色调，运动能量
# - 简约蓝 (minimal-blue) - 简约现代，蓝色调，科技清新
# - 专注绿 (focus-green) - 专注沉稳，绿色调，健康环保
默认主题 = 秋日暖光
# 启用主题轮换（每次运行自动更换主题，避免视觉疲劳）
启用主题轮换 = true
# 主题轮换状态文件路径
主题轮换状态文件 = ./theme_rotation.json

[广告图设置]
# 是否显示顶部广告图
显示顶部广告图 = true
顶部广告图路径 = ./image/top-ad.jpg
# 是否显示底部广告图
显示底部广告图 = true
底部广告图路径 = ./image/bottom-image.jpg

[任务调度]
# 是否启用定时任务（启动时立即运行1次）
启用定时任务 = true
# 运行频率（小时）- 每隔多少小时运行一次
运行间隔小时 = 2
# 停止运行时间（24小时制）- 超过此时间停止运行（北京时间）
停止运行小时 = 22
# 开始运行时间（24小时制）- 此时间之后才开始运行（北京时间）
开始运行小时 = 6

[企业微信通知]
# 企业微信机器人Webhook地址（需要替换为您的Webhook地址）
Webhook地址 = https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_WEBHOOK_KEY

[邮件通知]
# 邮件通知配置（可选，需要替换为您的邮箱配置）
接收邮箱 = YOUR_EMAIL@qq.com
SMTP服务器 = smtp.qq.com
SMTP端口 = 587
发件邮箱 = YOUR_EMAIL@qq.com
授权码 = YOUR_EMAIL_AUTH_CODE

[其他]
# 日志文件路径
日志文件路径 = ./zbbrain_article.log
# 临时文件目录
临时文件目录 = ./temp
# 调试模式（true/false）
调试模式 = false
# 最多重试次数
最多重试次数 = 5
